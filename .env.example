# ===========================================
# VIBE DJ - Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -------------------------------------------
# ANTHROPIC (Claude API) - REQUIRED
# -------------------------------------------
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Model selection (sonnet for speed, opus for complex curation)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -------------------------------------------
# SPOTIFY - REQUIRED
# -------------------------------------------
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create a new app
# 3. Add redirect URI: http://localhost:3000/api/auth/callback/spotify
# 4. Copy Client ID and Client Secret

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Redirect URI for OAuth (change for production)
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify

# -------------------------------------------
# ELEVENLABS (Voice DJ) - OPTIONAL for MVP
# -------------------------------------------
# Get your API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Voice ID for the DJ personality (choose from your ElevenLabs voice library)
ELEVENLABS_VOICE_ID=your_preferred_voice_id

# -------------------------------------------
# SONOS (Advanced Features) - OPTIONAL
# -------------------------------------------
# Only needed for advanced features like audio clip injection
# Most functionality works via Spotify Connect without this
# Get credentials from: https://developer.sonos.com/
SONOS_CLIENT_ID=your_sonos_client_id
SONOS_CLIENT_SECRET=your_sonos_client_secret

# -------------------------------------------
# DATABASE - LOCAL SQLITE
# -------------------------------------------
# Path to SQLite database file (taste profiles, session history)
DATABASE_URL=file:./data/vibe-dj.db

# -------------------------------------------
# APPLICATION
# -------------------------------------------
# Base URL for the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production URL (for Vercel)
# NEXT_PUBLIC_APP_URL=https://tunes.dylandibona.com

# Environment (development, production)
NODE_ENV=development

# -------------------------------------------
# OPTIONAL: ANALYTICS & MONITORING
# -------------------------------------------
# Vercel Analytics (auto-enabled on Vercel)
# VERCEL_ANALYTICS_ID=

# Error tracking (if using Sentry)
# SENTRY_DSN=
