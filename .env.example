# ==========================================
# Vibe DJ Environment Variables
# ==========================================
# Copy to .env.local and fill in values

# Required - Spotify OAuth (Phase 1)
# Get these from https://developer.spotify.com/dashboard
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=       # Client ID exposed to browser for PKCE flow
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify

# Required - Anthropic Claude API (Phase 4)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-            # Used automatically by @anthropic-ai/sdk

# Optional - ElevenLabs Voice DJ (Phase 9)
# Get from https://elevenlabs.io/
ELEVENLABS_API_KEY=sk_               # From ElevenLabs Dashboard
ELEVENLABS_VOICE_ID=                 # Selected voice ID

# Optional - Database (Phase 7+)
DATABASE_URL=file:./data/vibe-dj.db

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
